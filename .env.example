# Backend mode
# local (default) | supabase
VITE_BACKEND_PROVIDER=local

# Keep false for launch/offline-first
VITE_ENABLE_REMOTE_BACKEND_SYNC=false

# Runtime player/device identifiers (required when remote sync is enabled)
VITE_PLAYER_ID=local-player
VITE_DEVICE_ID=web-default-device

# Supabase (only required when VITE_BACKEND_PROVIDER=supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
